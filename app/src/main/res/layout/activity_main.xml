<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:paddingBottom="8dp" />

    <!-- NFC Status -->
    <TextView
        android:id="@+id/tvNfcStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_scan_hint"
        android:textSize="14sp"
        android:layout_gravity="center_horizontal"
        android:paddingBottom="16dp" />

    <!-- Active Card Indicator -->
    <LinearLayout
        android:id="@+id/layoutActiveCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E8EAF6"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvActiveLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_active_card"
            android:textSize="12sp"
            android:textColor="#6200EE" />

        <TextView
            android:id="@+id/tvActiveCardName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_no_active"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Card List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCardList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_no_cards"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_gravity="center_horizontal" />

    <!-- Scan Button -->
    <Button
        android:id="@+id/btnScanNfc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/main_add_card"
        android:layout_marginTop="16dp" />

</LinearLayout>
